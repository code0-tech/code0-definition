{
  "exclude": ["node_modules", "build", "dist"],
  "include": ["src/**/*"],
  "types": [
    "typePatches"
  ],
  "compilerOptions": {
    "lib": ["es2020"],
    "module": "commonjs",
    "target": "es2020",
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "src": [
        "src/*"
      ]
    },
    "baseUrl": "src/",
    "sourceMap": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
  }
}
